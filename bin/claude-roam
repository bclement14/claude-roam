#!/usr/bin/env bash
# shellcheck disable=SC2016,SC2029
# SC2016: Expressions don't expand in single quotes — FALSE POSITIVE in remote_sh() calls
#         intentionally use single quotes so $vars expand on the remote side.
# SC2029: Unescaped vars in SSH — FALSE POSITIVE, some vars must expand locally before SSH.
# claude-roam — move Claude Code sessions between machines.
#
# Run from the LOCAL machine (the one that can SSH to the remote).
#   push:  local -> remote        pull:  remote -> local
#
# Usage:
#   claude-roam push     <session-id>    Send a session to the remote
#   claude-roam pull     <session-id>    Fetch a session from the remote
#   claude-roam handoff  <session-id>    Stop remote claude + push + repo pull + extras + restart
#   claude-roam handback <session-id>    Stop remote claude + pull + extras
#   claude-roam project  <session-id> [remote]   Print the session's cwd
#   claude-roam repo-status <session-id> [remote]  git status of the local (or remote) project
#   claude-roam repo-pull   <session-id> git pull --ff-only in the remote project dir
#   claude-roam sync-extras <session-id> [to-remote|from-remote]
#   claude-roam sync-all    [both|to-remote|from-remote]
#   claude-roam list  [n]                List remote sessions (default 30)
#   claude-roam recent [n]               List local sessions (default 10)
#   claude-roam doctor                   Check prerequisites (local, and remote if configured)
#
# Options:
#   --remote <host>   Override remote for this run
#   --force           Skip the newer-side mtime check
#   --no-extras       Skip the sync-extras step inside handoff / handback
#   --no-stop         handoff/handback: do not stop (or restart) the remote
#                     claude. Skips pane discovery entirely and assumes YOU
#                     have already stopped the remote writer yourself.
#   --require-clean   Refuse (instead of warn) if a session's project repo
#                     has uncommitted or unpushed work
#   -h, --help        Show this help
#
# Config: ${XDG_CONFIG_HOME:-~/.config}/claude-roam/config (sourced shell).
# Env: CLAUDE_ROAM_REMOTE, CLAUDE_ROAM_PROJECTS, CLAUDE_ROAM_REMOTE_PROJECTS.

# ---- util / validate ----

die() { printf 'error: %s\n' "$*" >&2; exit 1; }
log() { printf '%s\n' "$*"; }

usage() { sed -n '/^# claude-roam/,/^$/p' "$0" | sed 's/^# \{0,1\}//'; }

# Session ids may only contain [A-Za-z0-9._-]: safe in regexes, tmux
# send-keys literals, and remote command lines.
validate_sid() {
  case "$1" in
    ""|*[!A-Za-z0-9._-]*) die "invalid session id: '$1' (allowed: A-Z a-z 0-9 . _ -)" ;;
  esac
}

# Escape ERE-active characters in a (validated) session id before it is
# interpolated into a `pgrep -f` extended regex. The sid allowlist is
# [A-Za-z0-9._-]; of those, only `.` is ERE-active (matches any character) —
# `-` is not special outside a bracket expression. Wrapping each literal dot
# in a one-character bracket expression `[.]` makes it match a literal dot
# only, so a dotted sid like "abc.def" can no longer match an unrelated
# string like "abcXdef" via the ERE wildcard.
sid_to_ere() {
  printf '%s' "$1" | sed 's/\./[.]/g'
}

validate_int() {
  case "$1" in
    ""|*[!0-9]*) die "expected a non-negative integer, got: '$1'" ;;
  esac
}

# Encoded form of an absolute path: /Users/alice -> -Users-alice
encode_path() { printf -- '-%s' "${1#/}" | tr '/' '-'; }

# ---- config ----

# Entries must be $HOME-relative, one path segment or nested, and free of
# characters that could break ssh/rsync command construction.
validate_rel_path() {
  case "$1" in
    ""|/*|-*)          die "config: invalid path entry '$1' (must be relative, must not start with '-')" ;;
    *..*)              die "config: invalid path entry '$1' ('..' not allowed)" ;;
    *[\'\`\$\"\\]*)    die "config: invalid path entry '$1' (quotes/metacharacters not allowed)" ;;
    *[[:space:]]*)     die "config: invalid path entry '$1' (whitespace not allowed)" ;;
  esac
}

validate_remote_alias() {
  case "$1" in
    ""|-*|*[[:space:]]*|*[\'\`\$\"\;\\]*) die "invalid remote host alias: '$1'" ;;
  esac
}

load_config() {
  # Capture env BEFORE sourcing config so env beats config. Empty == unset.
  local env_remote="${CLAUDE_ROAM_REMOTE:-}"

  # Neutral defaults.
  CLAUDE_ROAM_REMOTE=""
  PROJECT_ROOTS=(code)
  PROJECT_CLAUDE_EXTRAS=(plans reviews codebase-knowledge agent-memory agents skills)
  SESSION_DIR_EXTRAS=(memory)
  HOME_RELATIVE_EXTRAS=()

  PROJECTS="${CLAUDE_ROAM_PROJECTS:-$HOME/.claude/projects}"
  REMOTE_PROJECTS_OVERRIDE="${CLAUDE_ROAM_REMOTE_PROJECTS:-}"

  # The config is executable shell: protect it like a shell rc file.
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/claude-roam/config"
  if [ -f "$cfg" ]; then
    # shellcheck disable=SC1090
    . "$cfg"
  fi
  if [ -n "$env_remote" ]; then CLAUDE_ROAM_REMOTE="$env_remote"; fi

  if [ -n "$CLAUDE_ROAM_REMOTE" ]; then validate_remote_alias "$CLAUDE_ROAM_REMOTE"; fi
  local entry
  if [ ${#PROJECT_ROOTS[@]} -gt 0 ]; then
    for entry in "${PROJECT_ROOTS[@]}"; do validate_rel_path "$entry"; done
  fi
  if [ ${#PROJECT_CLAUDE_EXTRAS[@]} -gt 0 ]; then
    for entry in "${PROJECT_CLAUDE_EXTRAS[@]}"; do validate_rel_path "$entry"; done
  fi
  if [ ${#SESSION_DIR_EXTRAS[@]} -gt 0 ]; then
    for entry in "${SESSION_DIR_EXTRAS[@]}"; do validate_rel_path "$entry"; done
  fi
  if [ ${#HOME_RELATIVE_EXTRAS[@]} -gt 0 ]; then
    for entry in "${HOME_RELATIVE_EXTRAS[@]}"; do validate_rel_path "$entry"; done
  fi
}

# ---- remote / translation ----

# Deliberate top-level init (empty strings only): keeps set -u callers safe before require_remote runs.
REMOTE=""; RHOME=""; RPROJECTS=""

# Resolve the remote alias and remote $HOME. Called only by commands that
# actually touch the remote — local commands work with no remote configured.
require_remote() {
  if [ -n "$RHOME" ]; then return 0; fi
  REMOTE="${REMOTE_FLAG:-${CLAUDE_ROAM_REMOTE:-}}"
  if [ -z "$REMOTE" ]; then
    die "no remote configured: pass --remote <host>, set CLAUDE_ROAM_REMOTE, or edit ${XDG_CONFIG_HOME:-$HOME/.config}/claude-roam/config"
  fi
  validate_remote_alias "$REMOTE"
  RHOME="$(ssh "$REMOTE" 'printf %s "$HOME"')" || die "ssh to $REMOTE failed"
  if [ -z "$RHOME" ]; then die "remote \$HOME is empty"; fi
  RPROJECTS="${REMOTE_PROJECTS_OVERRIDE:-$RHOME/.claude/projects}"
}

local_home_encoded()  { encode_path "$HOME"; }
remote_home_encoded() { encode_path "$RHOME"; }

# Translate an encoded project-dir name between home prefixes. Match the
# prefix exactly OR followed by the next '-' separator, so -Users-alice
# does not match -Users-alice2.
translate_dir() {
  local dir="$1" direction="$2" lhp rhp
  lhp="$(local_home_encoded)"
  rhp="$(remote_home_encoded)"
  case "$direction" in
    to-remote)
      if [ "$dir" = "$lhp" ] || [[ "$dir" == "$lhp"-* ]]; then
        printf '%s%s' "$rhp" "${dir#"$lhp"}"
      else
        die "'$dir' is outside local \$HOME prefix '$lhp'; cannot translate"
      fi ;;
    to-local)
      if [ "$dir" = "$rhp" ] || [[ "$dir" == "$rhp"-* ]]; then
        printf '%s%s' "$lhp" "${dir#"$rhp"}"
      else
        die "'$dir' is outside remote \$HOME prefix '$rhp'; cannot translate"
      fi ;;
    *) die "internal: bad direction $direction" ;;
  esac
}

# POSIX shell single-quote escaping: ' -> '\'' , wrap in single quotes.
shq() { printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"; }

# Run a script on the remote. Script arrives on stdin (never interpolated);
# args are individually shell-quoted so the remote shell reassembles them
# as the exact argv. Usage: remote_sh <script> [args...]
remote_sh() {
  local script="$1" quoted="" a
  shift
  for a in "$@"; do quoted="$quoted $(shq "$a")"; done
  printf '%s' "$script" | ssh "$REMOTE" "bash -s --$quoted"
}

# Conservative gate for any path embedded in an ssh/rsync command line
# (rsync remote operands pass through the remote shell — quoting them
# portably across rsync variants is not reliable, so we reject anything
# shell-active and require absolute paths).
validate_path() {
  case "$1" in
    "")                 die "empty path (refusing)" ;;
    [!/]*)              die "path is not absolute (refusing): $1" ;;
    *[\'\`\$\"\\]*)     die "path contains shell-special characters (refusing): $1" ;;
    *[\;\&\|\(\)\<\>]*) die "path contains shell metacharacters (refusing): $1" ;;
    *[][{}*?]*)         die "path contains glob characters (refusing): $1" ;;
    *[[:space:]]*)      die "path contains whitespace (unsupported for remote transfer; rename or sync manually): $1" ;;
  esac
}

# Preflight wrapper for validate_path used by handoff/handback BEFORE they
# stop the remote claude: run the check in a subshell so its die doesn't
# exit us mid-message, then re-die with the original reason plus an explicit
# reassurance that the remote writer was never touched. Without this, a
# space/metachar path sails through the cwd preflight, the remote is
# stopped, and only THEN does cmd_push/cmd_pull's validate_path die --
# stranding a stopped remote with no transfer and no resume hint.
_preflight_validate_path() {
  local err rc=0
  err="$( (validate_path "$1") 2>&1 )" || rc=$?
  if [ "$rc" -ne 0 ]; then
    die "${err#error: } (remote claude was NOT stopped)"
  fi
}

# ---- sessions / compare ----

find_local_session() {
  local sid="$1" matches count
  matches="$(find "$PROJECTS" -maxdepth 2 -name "${sid}.jsonl" 2>/dev/null || true)"
  if [ -z "$matches" ]; then
    die "session $sid not found locally under $PROJECTS"
  fi
  count="$(printf '%s\n' "$matches" | grep -c .)"
  if [ "$count" -gt 1 ]; then
    die "ambiguous session id $sid — multiple matches:
$matches"
  fi
  printf '%s' "$matches"
}

find_remote_session() {
  local sid="$1" matches count
  matches="$(remote_sh 'find "$1" -maxdepth 2 -name "$2.jsonl" 2>/dev/null' \
    "$RPROJECTS" "$sid" || true)"
  if [ -z "$matches" ]; then
    die "session $sid not found on remote $REMOTE under $RPROJECTS"
  fi
  count="$(printf '%s\n' "$matches" | grep -c .)"
  if [ "$count" -gt 1 ]; then
    die "ambiguous session id $sid on remote $REMOTE — multiple matches:
$matches"
  fi
  printf '%s' "$matches"
}

# GNU first: BSD stat errors on -c (clean fallback), but GNU stat "succeeds"
# with filesystem info on -f — so BSD-first silently breaks Linux.
local_mtime() { stat -c %Y "$1" 2>/dev/null || stat -f %m "$1"; }
local_size()  { stat -c %s "$1" 2>/dev/null || stat -f %z "$1"; }

# One round trip. Prints one of:
#   "MISSING"         remote file genuinely absent (ssh/stat succeeded)
#   "<mtime> <size>"  remote file present
# Returns nonzero (no "|| true" swallow) when the ssh/remote script itself
# fails -- callers MUST check the exit code, not just the (possibly empty)
# output, so a transport failure is never mistaken for "file missing".
remote_stat() {
  remote_sh 'f="$1"
m=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null) || { printf "MISSING"; exit 0; }
[ -n "$m" ] || { printf "MISSING"; exit 0; }
s=$(stat -c %s "$f" 2>/dev/null || stat -f %z "$f" 2>/dev/null)
printf "%s %s" "$m" "$s"' "$1"
}

# local-newer | remote-newer | equal | diverged | local-missing | remote-missing | remote-unknown
compare_mtimes() {
  local lf="$1" rf="$2" lt ls rstat rc=0 rt rs
  if [ ! -f "$lf" ]; then
    printf 'local-missing'
    return
  fi
  lt="$(local_mtime "$lf")"
  ls="$(local_size "$lf")"
  rstat="$(remote_stat "$rf")" || rc=$?
  if [ "$rc" -ne 0 ]; then
    # ssh/stat itself failed -- we genuinely don't know the remote state.
    # NOT remote-missing: that would let push/pull proceed as if the
    # remote copy doesn't exist, which is the permissive (overwrite) branch.
    printf 'remote-unknown'
    return
  fi
  if [ -z "$rstat" ] || [ "$rstat" = "MISSING" ]; then
    printf 'remote-missing'
    return
  fi
  rt="${rstat%% *}"
  rs="${rstat#* }"
  if [ "$lt" -gt "$rt" ]; then
    printf 'local-newer'
  elif [ "$lt" -lt "$rt" ]; then
    printf 'remote-newer'
  elif [ "$ls" = "$rs" ]; then
    printf 'equal'
  else
    printf 'diverged'
  fi
}

# Best-effort remote file size for the size-shrink guard below: prints the
# byte count, or empty if the file is missing/unknown (ssh failed). Empty
# means "nothing to compare against" to the guard, i.e. it skips rather
# than refuses -- the remote-unknown/remote-missing state machine above is
# what's responsible for refusing when we can't read the other side at all.
_remote_size_or_empty() {
  local rstat rc=0
  rstat="$(remote_stat "$1")" || rc=$?
  if [ "$rc" -ne 0 ] || [ -z "$rstat" ] || [ "$rstat" = "MISSING" ]; then
    printf ''
  else
    printf '%s' "${rstat#* }"
  fi
}

# Direction-aware "destination shouldn't shrink" guard (H1 clock-skew +
# H3 fork): session JSONLs are append-mostly and only grow, so a transfer
# whose destination is already LARGER than the source about to overwrite
# it is a strong signal of clock skew (the mtime-based "newer" verdict
# above was inverted) or an independent fork with differing mtimes -- a
# case the mtime state machine's `diverged` bucket does NOT catch (it only
# fires on an exact mtime tie). This is an added safety gate alongside that
# state machine, not a replacement for it. Pass "" for dest_size to skip
# (destination missing or its size couldn't be determined).
refuse_if_dest_shrinks() {
  local src_size="$1" dest_size="$2"
  [ -n "$dest_size" ] || return 0
  if [ "$dest_size" -gt "$src_size" ]; then
    die "refusing to overwrite a larger file ($dest_size bytes) with a smaller one ($src_size bytes) — likely a clock-skew or forked session; pass --force to override"
  fi
}

# ---- force-overwrite backup ----

# A --force overwrite is the one destructive operation in the tool: it
# clobbers the destination copy. Before that happens to an EXISTING file,
# stash the losing copy to ~/.claude/roam-backups/<sid>.<UTC-timestamp>.jsonl
# on the machine that holds it (local for pull, remote for push), so it is
# always recoverable; then prune stashes older than 30 days. Best-effort by
# design: the user asked to force, so a failed backup WARNS but never blocks
# the overwrite, and a pruning failure never fails the transfer. Nothing is
# stashed on a normal (non-force) transfer or when the destination is
# missing (nothing to lose).

_backup_filename() { printf '%s.%s.jsonl' "$1" "$(date -u +%Y%m%dT%H%M%SZ)"; }

# pull --force: the destination being overwritten is the LOCAL file ($2).
backup_local_before_force() {
  local sid="$1" dest="$2" bdir backup
  [ "${FORCE:-0}" -eq 1 ] || return 0
  [ -f "$dest" ] || return 0
  bdir="$HOME/.claude/roam-backups"
  backup="$bdir/$(_backup_filename "$sid")"
  if mkdir -p "$bdir" 2>/dev/null && cp "$dest" "$backup" 2>/dev/null; then
    log "backed up prior local copy -> $backup"
  else
    log "WARNING: could not back up $dest to $backup — the forced overwrite proceeds WITHOUT a backup"
  fi
  find "$bdir" -name '*.jsonl' -type f -mtime +30 -delete 2>/dev/null || true
  return 0
}

# push --force: the destination is the REMOTE file ($2); stash it on the
# remote in one round trip (existence already adjudicated: $3 is cmd_push's
# compare_mtimes verdict, and remote-missing means nothing to back up).
# Both paths travel as quoted argv via remote_sh, never interpolated.
backup_remote_before_force() {
  local sid="$1" rfile="$2" cmp="$3" bdir backup
  [ "${FORCE:-0}" -eq 1 ] || return 0
  [ "$cmp" != "remote-missing" ] || return 0
  bdir="$RHOME/.claude/roam-backups"
  backup="$bdir/$(_backup_filename "$sid")"
  # rfile already passed cmd_push's validate_path; backup adds only $RHOME
  # plus sid/timestamp characters. Re-check both anyway — in a subshell,
  # downgrading a refusal to a warning, because a skipped backup must not
  # abort the forced transfer the user asked for.
  if ! ( validate_path "$rfile" && validate_path "$backup" ) >/dev/null 2>&1; then
    log "WARNING: backup path failed validation ($backup) — the forced overwrite proceeds WITHOUT a backup"
    return 0
  fi
  if remote_sh 'mkdir -p "$2" && cp "$1" "$3" || exit 1
find "$2" -name "*.jsonl" -type f -mtime +30 -delete 2>/dev/null || true
exit 0' "$rfile" "$bdir" "$backup"; then
    log "backed up prior remote copy -> $REMOTE:$backup"
  else
    log "WARNING: could not back up $REMOTE:$rfile to $backup — the forced overwrite proceeds WITHOUT a backup"
  fi
  return 0
}

# ---- push / pull ----

cmd_push() {
  local sid="$1" local_file local_dir local_name remote_name remote_dir remote_file cmp pre post lcwd
  require_remote
  local_file="$(find_local_session "$sid")"
  local_dir="$(dirname "$local_file")"
  local_name="$(basename "$local_dir")"
  remote_name="$(translate_dir "$local_name" to-remote)"
  remote_dir="$RPROJECTS/$remote_name"
  remote_file="$remote_dir/${sid}.jsonl"
  validate_path "$remote_file"

  # git moves the session's CODE separately from this JSONL transfer -- warn
  # (or, with --require-clean, refuse) if the project repo isn't fully
  # committed and pushed. A session with no discoverable cwd (or one whose
  # cwd isn't a repo) has nothing to check, so failure to resolve it here
  # must never break the push itself.
  lcwd="$(session_cwd_local "$sid" 2>/dev/null || true)"
  if [ -n "$lcwd" ]; then
    if ! warn_repo_unclean "$lcwd" "$lcwd"; then
      if [ "${REQUIRE_CLEAN:-0}" -eq 1 ]; then
        die "refusing to push: project repo at $lcwd is not clean (see WARNING above) — commit and push it, or drop --require-clean to proceed anyway"
      fi
    fi
  fi

  cmp="$(compare_mtimes "$local_file" "$remote_file")"
  log "local : $local_file"
  log "remote: $REMOTE:$remote_file"
  log "state : $cmp"
  if [ "$cmp" = "remote-unknown" ]; then
    die "could not determine remote state (ssh/stat failed) — refusing to push; never overwrite when we can't read the other side. Check connectivity and retry"
  fi
  if [ "$cmp" = "remote-newer" ] && [ "$FORCE" -ne 1 ]; then
    die "remote is newer; pull first or pass --force to overwrite"
  fi
  if [ "$cmp" = "diverged" ] && [ "$FORCE" -ne 1 ]; then
    die "same mtime but different size — the copies have diverged; decide which side wins and re-run with --force from that side"
  fi
  if [ "$FORCE" -ne 1 ]; then
    refuse_if_dest_shrinks "$(local_size "$local_file")" "$(_remote_size_or_empty "$remote_file")"
  fi
  # Forced overwrite of an existing remote copy: stash the losing copy on
  # the remote first (best-effort; warns instead of blocking on failure).
  backup_remote_before_force "$sid" "$remote_file" "$cmp"

  pre="$(local_mtime "$local_file") $(local_size "$local_file")"
  remote_sh 'mkdir -p "$1"' "$remote_dir" || return $?
  # -I/--ignore-times: rsync's default quick-check is size+mtime, so equal
  # metadata with different bytes (see compare_mtimes' "diverged" verdict,
  # and equal-metadata cases --force is meant to override) would otherwise
  # be silently skipped even though we already decided a transfer is wanted.
  rsync -aI --progress "$local_file" "$REMOTE:$remote_file" || return $?
  post="$(local_mtime "$local_file") $(local_size "$local_file")"
  if [ "$pre" != "$post" ]; then
    log "WARNING: the session file changed during transfer — a Claude is likely still writing it here. Stop it and re-run push."
  fi
  if [ "$cmp" = "equal" ]; then
    log "already in sync: $sid (no transfer needed)"
  else
    log "pushed $sid"
  fi
}

cmd_pull() {
  local sid="$1" remote_file remote_dir remote_name local_name local_dir local_file cmp pre post pre_rc post_rc
  require_remote
  remote_file="$(find_remote_session "$sid")"
  remote_dir="$(dirname "$remote_file")"
  remote_name="$(basename "$remote_dir")"
  local_name="$(translate_dir "$remote_name" to-local)"
  local_dir="$PROJECTS/$local_name"
  local_file="$local_dir/${sid}.jsonl"
  validate_path "$remote_file"

  cmp="$(compare_mtimes "$local_file" "$remote_file")"
  log "remote: $REMOTE:$remote_file"
  log "local : $local_file"
  log "state : $cmp"
  if [ "$cmp" = "remote-unknown" ]; then
    die "could not determine remote state (ssh/stat failed) — refusing to pull; never overwrite when we can't read the other side. Check connectivity and retry"
  fi
  if [ "$cmp" = "local-newer" ] && [ "$FORCE" -ne 1 ]; then
    die "local is newer; push first or pass --force to overwrite"
  fi
  if [ "$cmp" = "diverged" ] && [ "$FORCE" -ne 1 ]; then
    die "same mtime but different size — the copies have diverged; decide which side wins and re-run with --force from that side"
  fi
  if [ "$FORCE" -ne 1 ]; then
    local dest_size=""
    [ -f "$local_file" ] && dest_size="$(local_size "$local_file")"
    refuse_if_dest_shrinks "$(_remote_size_or_empty "$remote_file")" "$dest_size"
  fi
  # Forced overwrite of an existing local copy: stash the losing copy
  # locally first (best-effort; warns instead of blocking on failure).
  backup_local_before_force "$sid" "$local_file"
  mkdir -p "$local_dir" || return $?
  # Liveness check (M5): snapshot the REMOTE source's mtime+size around the
  # transfer, mirroring cmd_push's local pre/post snapshot — if the remote
  # file changed while rsync ran, a Claude is likely still writing it there
  # and the pulled bytes may be a torn (mid-write) snapshot. Advisory only:
  # it WARNS and never fails, consistent with push. Skipped when either
  # snapshot is unavailable (transport error, empty, or MISSING) so a flaky
  # ssh can't false-alarm. Costs two extra remote stat round trips.
  pre_rc=0; post_rc=0
  pre="$(remote_stat "$remote_file")" || pre_rc=$?
  # -I/--ignore-times: see the matching comment in cmd_push — skip rsync's
  # size+mtime quick-check so an already-adjudicated transfer always sends
  # the bytes, even when source and destination share size and mtime.
  rsync -aI --progress "$REMOTE:$remote_file" "$local_file" || return $?
  post="$(remote_stat "$remote_file")" || post_rc=$?
  if [ "$pre_rc" -eq 0 ] && [ "$post_rc" -eq 0 ] \
    && [ -n "$pre" ] && [ -n "$post" ] \
    && [ "$pre" != "MISSING" ] && [ "$post" != "MISSING" ] \
    && [ "$pre" != "$post" ]; then
    log "WARNING: the remote session file changed during transfer — a Claude is likely still writing it there; the pulled copy may be an incomplete snapshot. Stop it and re-run pull."
  fi
  if [ "$cmp" = "equal" ]; then
    log "already in sync: $sid (no transfer needed)"
  else
    log "pulled $sid"
  fi
}

# ---- project / repo ----

# A session's local project cwd is resolved from the JSONL `cwd` records --
# NOT by decoding the encoded directory name, which is ambiguous (both '/'
# and a literal '-' encode to '-'). A transcript that ORIGINATED on the
# remote still carries a remote-home cwd (e.g. /home/alice/...) even after it
# lands in the correctly-translated local project dir, so we recover the
# LOCAL path by matching each candidate against the session file's encoded
# parent directory name (which push/pull already translate correctly).
#
# POSIX-sh snippet that reads a JSONL file ($1) and prints each *string*
# `.cwd` value, one per line, EXCLUDING any value containing a newline or
# carriage return. Excluding embedded newlines is what makes the plain
# newline-delimited framing safe: a crafted `"evil\n/other"` cwd is dropped
# rather than split into a phantom second candidate. A legitimate project
# cwd never contains a newline. Requires a REAL JSON parser (jq or python3):
# the old grep/sed fallback scanned physical lines with no JSON framing, so
# a torn record (raw newline inside a JSON string) could emit a phantom cwd
# that silently resolves to the WRONG directory. With neither parser present
# the snippet exits 3 with an install hint; callers surface that as a hard,
# actionable failure instead of "no candidates". Used verbatim on both the
# local machine and (via remote_sh) the remote, so the two parser modes
# frame candidates identically on both sides.
cwd_extract_script() {
cat <<'SH'
f="$1"
if command -v jq >/dev/null 2>&1; then
  jq -R -r 'fromjson? | select(type=="object") | .cwd | select(type=="string") | select((contains("\n") or contains("\r")) | not)' "$f" 2>/dev/null
elif command -v python3 >/dev/null 2>&1; then
  python3 -c '
import json, sys
with open(sys.argv[1]) as fh:
    for line in fh:
        try:
            o = json.loads(line)
        except Exception:
            continue
        if isinstance(o, dict):
            c = o.get("cwd")
            if isinstance(c, str) and "\n" not in c and "\r" not in c:
                print(c)
' "$f" 2>/dev/null
else
  echo "cwd resolution requires jq or python3; install one" >&2
  exit 3
fi
SH
}

# Run the extractor locally against $1. A missing JSON parser is a hard,
# actionable failure (the snippet exits 3; die here with the install hint).
# Any other nonzero (unreadable file / no matches) still reads as "no
# candidates", so the resolver's own "no cwd record matches" diagnostic
# fires instead of a spurious pipeline failure.
_extract_cwd_candidates() {
  local out rc=0
  out="$(bash -c "$(cwd_extract_script)" _ "$1" 2>/dev/null)" || rc=$?
  if [ "$rc" -eq 3 ]; then
    die "cwd resolution requires jq or python3; install one"
  fi
  printf '%s' "$out"
}

# Validate one candidate is an absolute, lexically-normal path. Strips a
# single trailing slash (harmless) but REFUSES '//', '/./', '/../', and bare
# '.'/'..' components rather than resolving them (they could textually match
# the encoded parent while pointing elsewhere). Prints the cleaned path, or
# returns 1.
_clean_abs_cwd() {
  local p="$1"
  case "$p" in
    /)  printf '/'; return 0 ;;
    /*) ;;
    *)  return 1 ;;
  esac
  case "$p" in
    *//*|*/./*|*/../*|*/.|*/..) return 1 ;;
  esac
  case "$p" in */) p="${p%/}" ;; esac
  printf '%s' "$p"
}

# Resolve one cleaned candidate ($1) to a LOCAL cwd, given the session file's
# encoded parent dir name ($2) and the encoded local $HOME ($3). Prints the
# local path and returns 0 on a match, else returns 1.
#   Direct match:  the candidate already encodes to the parent (local-origin,
#                  or a session whose project sits outside $HOME).
#   Foreign match: ONLY when the parent is the encoded local $HOME or a child
#                  of it. Encoding is length-preserving, so the last k chars
#                  of the candidate (k = length of the parent's tail past the
#                  home prefix) are the relative suffix; its slashes must
#                  encode back to that tail. k=0 (parent IS $HOME) maps any
#                  candidate to $HOME. NOTE: because '/' and '-' collide under
#                  encoding, this trusts the candidate's own slash placement;
#                  it authenticates a legitimate remote-origin path but cannot
#                  detect a maliciously slash-shifted single record.
_resolve_cwd_candidate() {
  local c="$1" parent="$2" lhp="$3" tail k clen suffix enc
  enc="$(encode_path "$c")"
  if [ "$enc" = "$parent" ]; then
    printf '%s' "$c"
    return 0
  fi
  if [ "$parent" = "$lhp" ] || [[ "$parent" == "$lhp"-* ]]; then
    tail="${parent#"$lhp"}"
    k="${#tail}"
    clen="${#c}"
    if [ "$k" -eq 0 ]; then
      printf '%s' "$HOME"
      return 0
    fi
    if [ "$clen" -ge "$k" ]; then
      suffix="${c:$((clen - k))}"
      case "$suffix" in
        /*)
          if [ "$(printf '%s' "$suffix" | tr '/' '-')" = "$tail" ]; then
            printf '%s%s' "$HOME" "$suffix"
            return 0
          fi
          ;;
      esac
    fi
  fi
  return 1
}

# Read newline-delimited candidates on stdin, resolve each against parent $1,
# and emit the single agreed-upon local path. Distinct validating results are
# an ambiguity refusal.
#   prints path, returns 0  -- exactly one distinct resolution
#   returns 1               -- no candidate matched the parent
#   returns 2               -- candidates resolved to conflicting local paths
_resolve_cwd_stream() {
  local parent="$1" lhp resolved="" found=0 ambiguous=0 raw cand r
  lhp="$(encode_path "$HOME")"
  while IFS= read -r raw || [ -n "$raw" ]; do
    [ -n "$raw" ] || continue
    cand="$(_clean_abs_cwd "$raw")" || continue
    r="$(_resolve_cwd_candidate "$cand" "$parent" "$lhp")" || continue
    [ -n "$r" ] || continue
    if [ "$found" -eq 0 ]; then
      resolved="$r"; found=1
    elif [ "$r" != "$resolved" ]; then
      ambiguous=1
    fi
  done
  if [ "$ambiguous" -eq 1 ]; then return 2; fi
  if [ "$found" -eq 0 ]; then return 1; fi
  printf '%s' "$resolved"
}

# Authoritative LOCAL project cwd for a session: resolve the JSONL's cwd
# records against the (correctly-translated) local parent directory name.
session_cwd_local() {
  local sid="$1" file parent cands out rc=0
  file="$(find_local_session "$sid")"
  parent="$(basename "$(dirname "$file")")"
  # Extraction runs OUTSIDE the resolve pipeline so a die inside it (missing
  # jq/python3) surfaces as this function's own failure with its message
  # intact, instead of being flattened into "no cwd record matches" below.
  cands="$(_extract_cwd_candidates "$file")" || return $?
  out="$(printf '%s' "$cands" | _resolve_cwd_stream "$parent")" || rc=$?
  if [ "$rc" -eq 2 ]; then
    die "session $sid has cwd records resolving to different local project dirs; refusing to guess (project '$parent')"
  fi
  if [ "$rc" -ne 0 ] || [ -z "$out" ]; then
    die "could not resolve a local cwd for session $sid: no cwd record matches its project dir '$parent'"
  fi
  printf '%s' "$out"
}

# Translate the local cwd to the corresponding path under the remote's $HOME.
# Require exact $HOME or $HOME/... so /Users/alice2/foo doesn't match /Users/alice.
session_cwd_remote() {
  local sid="$1" local_cwd
  require_remote
  local_cwd="$(session_cwd_local "$sid")"
  [ -n "$local_cwd" ] || die "could not read cwd from session $sid"
  if [ "$local_cwd" != "$HOME" ] && [[ "$local_cwd" != "$HOME"/* ]]; then
    die "session cwd '$local_cwd' is outside local \$HOME; cannot translate"
  fi
  printf '%s%s' "$RHOME" "${local_cwd#"$HOME"}"
}

cmd_project() {
  local sid="$1" mode="${2:-local}"
  case "$mode" in
    local)  session_cwd_local  "$sid"; echo ;;
    remote) session_cwd_remote "$sid"; echo ;;
    *) die "project: unknown mode '$mode' (use 'local' or 'remote')" ;;
  esac
}

# git moves a session's CODE separately from the JSONL claude-roam
# transfers -- if the project repo at <cwd> has uncommitted or unpushed
# work, a synced session can end up referencing code that isn't reachable
# on the other machine yet. Sets the global REPO_STATE to exactly one of:
#   clean       no uncommitted changes, and (if the branch has an upstream)
#               fully pushed to it
#   dirty       uncommitted changes present (staged, unstaged, or untracked)
#   unpushed    clean, but the current branch is ahead of its upstream
#   no-upstream clean, but the branch has no upstream at all -- the code
#               isn't confirmed to be on any remote
#   not-a-repo  <cwd> exists but is not a git repo
#   no-dir      <cwd> does not exist
# If the repo is BOTH dirty and ahead of (or missing) an upstream,
# REPO_STATE reports "dirty" (the more urgent condition) but REPO_UNPUSHED=1
# is also set, so a caller can mention both conditions in one message.
# REPO_AHEAD_COUNT is the commit count ahead of upstream (0 if not
# applicable) so callers can report "N unpushed commit(s)".
repo_sync_state() {
  local cwd="$1" upstream
  REPO_STATE=""
  REPO_UNPUSHED=0
  REPO_AHEAD_COUNT=0
  if [ ! -d "$cwd" ]; then
    REPO_STATE="no-dir"
    return 0
  fi
  if ! git -C "$cwd" rev-parse --show-toplevel >/dev/null 2>&1; then
    REPO_STATE="not-a-repo"
    return 0
  fi
  if [ -n "$(git -C "$cwd" status --porcelain 2>/dev/null)" ]; then
    REPO_STATE="dirty"
  fi
  upstream="$(git -C "$cwd" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)" || true
  if [ -z "$upstream" ]; then
    if [ "$REPO_STATE" = "dirty" ]; then
      REPO_UNPUSHED=1
    else
      REPO_STATE="no-upstream"
    fi
  else
    REPO_AHEAD_COUNT="$(git -C "$cwd" rev-list --count '@{u}..HEAD' 2>/dev/null)" || REPO_AHEAD_COUNT=""
    case "$REPO_AHEAD_COUNT" in ''|*[!0-9]*) REPO_AHEAD_COUNT=0 ;; esac
    if [ "$REPO_AHEAD_COUNT" -gt 0 ]; then
      if [ "$REPO_STATE" = "dirty" ]; then
        REPO_UNPUSHED=1
      else
        REPO_STATE="unpushed"
      fi
    fi
  fi
  [ -n "$REPO_STATE" ] || REPO_STATE="clean"
  return 0
}

# Advisory warning (never a hard failure -- the caller decides via
# REQUIRE_CLEAN) that <cwd>'s repo (named <label> in the message) has
# uncommitted or unpushed work, printed prominently to STDERR so it isn't
# lost among the normal STDOUT transfer log. Returns 1 if it warned, 0 if
# the repo is clean, not a repo, or missing (nothing to warn about).
warn_repo_unclean() {
  local cwd="$1" label="$2" detail=""
  repo_sync_state "$cwd"
  case "$REPO_STATE" in
    clean|not-a-repo|no-dir) return 0 ;;
  esac
  case "$REPO_STATE" in
    dirty)
      detail="has uncommitted changes"
      if [ "$REPO_UNPUSHED" -eq 1 ]; then
        if [ "$REPO_AHEAD_COUNT" -gt 0 ]; then
          detail="$detail and $REPO_AHEAD_COUNT unpushed commit(s)"
        else
          detail="$detail and its branch has no upstream"
        fi
      fi
      ;;
    unpushed)    detail="has $REPO_AHEAD_COUNT unpushed commit(s)" ;;
    no-upstream) detail="is on a branch with no upstream (its code isn't confirmed to be on any remote)" ;;
  esac
  {
    printf 'WARNING: %s %s\n' "$label" "$detail"
    printf '  the synced session may reference code that is not on the other machine.\n'
    printf '  commit & push it first, or re-run with --require-clean to make this a hard stop.\n'
  } >&2
  return 1
}

cmd_repo_status() {
  local sid="$1" cwd
  cwd="$(session_cwd_local "$sid")"
  [ -d "$cwd" ] || die "project dir '$cwd' does not exist"
  if ! git -C "$cwd" rev-parse --show-toplevel >/dev/null 2>&1; then
    log "not-a-repo: $cwd"
    return 0
  fi
  log "repo: $(git -C "$cwd" rev-parse --show-toplevel)"
  log "branch: $(git -C "$cwd" rev-parse --abbrev-ref HEAD)"
  log "--- status ---"
  git -C "$cwd" status --short --branch
}

# Remote counterpart of cmd_repo_status. The remote cwd comes from a pulled
# JSONL (semi-untrusted -- it originated on another machine), so it MUST be
# passed to the remote shell as a quoted argv element via remote_sh, never
# interpolated into a hand-built ssh/rsync command string: a cwd containing
# a quote or shell metacharacter would otherwise inject into that command
# (see docs/skill's old raw-ssh recipe, replaced by this subcommand).
cmd_repo_status_remote() {
  local sid="$1" rcwd
  require_remote
  rcwd="$(session_cwd_remote "$sid")" || return $?
  log "remote: $REMOTE:$rcwd"
  remote_sh 'cd "$1" 2>/dev/null || { echo "remote dir missing or not a repo"; exit 0; }
git rev-parse --show-toplevel >/dev/null 2>&1 || { echo "not-a-repo: $1"; exit 0; }
git status --short --branch' "$rcwd"
}

cmd_repo_pull() {
  local sid="$1" expected_branch="${2:-}" rcwd
  require_remote
  rcwd="$(session_cwd_remote "$sid")" || return $?
  log "pulling on $REMOTE:$rcwd"
  remote_sh 'set -u
rcwd="$1"; want="$2"
cd "$rcwd" 2>/dev/null || { echo "remote dir does not exist: $rcwd"; exit 0; }
if ! git rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "not-a-repo: $rcwd"; exit 0
fi
cur="$(git rev-parse --abbrev-ref HEAD)"
if [ -n "$want" ] && [ "$cur" != "$want" ]; then
  echo "BRANCH-MISMATCH: remote is on $cur, local pushed $want — skipping pull"
  exit 0
fi
echo "before:"; git status --short --branch
pull_rc=0
git pull --ff-only || pull_rc=$?
echo "after:";  git status --short --branch
exit "$pull_rc"' "$rcwd" "$expected_branch"
}

# ---- listing ----

cmd_list() {
  local n="${1:-30}" raw
  require_remote
  raw="$(remote_sh 'set -u
root="$1"; n="$2"
find "$root" -maxdepth 2 -name "*.jsonl" 2>/dev/null | while read -r f; do
  t=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null)
  [ -n "$t" ] && printf "%s %s\n" "$t" "$f"
done | sort -rn | head -n "$n"' "$RPROJECTS" "$n")"
  printf '%s\n' "$raw" | while read -r ts path; do
    [ -n "$ts" ] || continue
    ts_int="${ts%.*}"
    name="${path##*/}"
    sid="${name%.jsonl}"
    printf '%s  %s  %s\n' \
      "$(date -r "$ts_int" '+%Y-%m-%d %H:%M' 2>/dev/null || date -d "@$ts_int" '+%Y-%m-%d %H:%M')" \
      "$sid" "$path"
  done
}

cmd_recent() {
  local n="${1:-10}"
  # head closes the pipe early once output exceeds the buffer; without
  # disabling pipefail the SIGPIPE'd sort/find fails the whole pipeline
  # at a few hundred sessions.
  (
    set +o pipefail
    find "$PROJECTS" -maxdepth 2 -name '*.jsonl' -print 2>/dev/null \
      | while read -r f; do
          printf '%s\t%s\n' "$(local_mtime "$f")" "$f"
        done \
      | sort -rn | head -"$n" \
      | while IFS=$'\t' read -r ts path; do
          name="${path##*/}"
          sid="${name%.jsonl}"
          printf '%s  %s  %s\n' "$(date -r "$ts" '+%Y-%m-%d %H:%M' 2>/dev/null || date -d "@$ts" '+%Y-%m-%d %H:%M')" "$sid" "$path"
        done
  )
}

# ---- sync-extras ----

# Sync helpers — rsync -au means "update only if source is newer", which is
# safer than blind replace for working-doc dirs that might be edited on both
# sides. The added -v lists every file actually transferred, so an empty
# listing (beyond the header/summary lines) is itself the verification that
# nothing needed moving. Logs nothing if the source dir doesn't exist
# (silent no-op).
_sync_to() {
  local src="$1" rdst="$2"
  [ -d "$src" ] || return 0
  validate_path "$rdst"
  # Explicit `|| return $?` on every fallible step: this function is called
  # from `sync_try`/`||` contexts that disable `errexit` for its whole
  # invocation, so a failure must be propagated explicitly, not left to
  # `set -e` (see the H1 comment on cmd_push).
  remote_sh 'mkdir -p "$1"' "$rdst" || return $?
  log "  $src/  ->  $REMOTE:$rdst/"
  rsync -auv "$src/" "$REMOTE:$rdst/" || return $?
}

_sync_from() {
  local rsrc="$1" dst="$2" out
  validate_path "$rsrc"
  # Two-word sentinel protocol so an ssh/transport failure (remote_sh
  # returns nonzero) is never confused with "directory genuinely absent"
  # (remote_sh succeeds and prints NO) -- the old `remote_sh '[ -d "$1" ]'
  # ... || return 0` collapsed both cases into a silent no-op.
  out="$(remote_sh '[ -d "$1" ] && echo YES || echo NO' "$rsrc")" || return $?
  [ "$out" = "YES" ] || return 0
  mkdir -p "$dst"
  log "  $REMOTE:$rsrc/  ->  $dst/"
  rsync -auv "$REMOTE:$rsrc/" "$dst/" || return $?
}

cmd_sync_extras() {
  # Optional args 3/4 let a caller (handback) pass an already-validated
  # local/remote cwd so this step never re-parses mutable data. When absent
  # (standalone / handoff), resolve here -- with explicit `|| return $?` so a
  # resolver failure can't degrade into an empty-path no-op under the
  # errexit-disabling `||` call contexts (see the H1/H4 comments elsewhere).
  local sid="$1" direction="${2:-to-remote}" lcwd="${3:-}" rcwd="${4:-}"
  local lenc enc_name renc_name renc sub rel
  require_remote

  if [ -z "$lcwd" ]; then lcwd="$(session_cwd_local "$sid")" || return $?; fi
  if [ -z "$rcwd" ]; then rcwd="$(session_cwd_remote "$sid")" || return $?; fi
  lenc="$(dirname "$(find_local_session "$sid")")" || return $?
  enc_name="$(basename "$lenc")"
  renc_name="$(translate_dir "$enc_name" to-remote)"
  renc="$RPROJECTS/$renc_name"

  case "$direction" in
    to-remote)
      log "syncing extras: local -> $REMOTE"
      if [ ${#PROJECT_CLAUDE_EXTRAS[@]} -gt 0 ]; then
        for sub in "${PROJECT_CLAUDE_EXTRAS[@]}"; do
          _sync_to "$lcwd/.claude/$sub" "$rcwd/.claude/$sub" || return $?
        done
      fi
      if [ ${#SESSION_DIR_EXTRAS[@]} -gt 0 ]; then
        for sub in "${SESSION_DIR_EXTRAS[@]}"; do
          _sync_to "$lenc/$sub" "$renc/$sub" || return $?
        done
      fi
      if [ ${#HOME_RELATIVE_EXTRAS[@]} -gt 0 ]; then
        for rel in "${HOME_RELATIVE_EXTRAS[@]}"; do
          _sync_to "$HOME/$rel" "$RHOME/$rel" || return $?
        done
      fi
      ;;
    from-remote)
      log "syncing extras: $REMOTE -> local"
      if [ ${#PROJECT_CLAUDE_EXTRAS[@]} -gt 0 ]; then
        for sub in "${PROJECT_CLAUDE_EXTRAS[@]}"; do
          _sync_from "$rcwd/.claude/$sub" "$lcwd/.claude/$sub" || return $?
        done
      fi
      if [ ${#SESSION_DIR_EXTRAS[@]} -gt 0 ]; then
        for sub in "${SESSION_DIR_EXTRAS[@]}"; do
          _sync_from "$renc/$sub" "$lenc/$sub" || return $?
        done
      fi
      if [ ${#HOME_RELATIVE_EXTRAS[@]} -gt 0 ]; then
        for rel in "${HOME_RELATIVE_EXTRAS[@]}"; do
          _sync_from "$RHOME/$rel" "$HOME/$rel" || return $?
        done
      fi
      ;;
    *) die "sync-extras: unknown direction '$direction' (use 'to-remote' or 'from-remote')" ;;
  esac
}

# ---- sync-all ----

FAILED_N=0
# Run a step; count failure instead of dying (set -e safe because the caller
# invokes us in a condition when needed). Logs the failed step.
sync_try() {
  # Run in a subshell: isolates BOTH a plain command failure AND a die-exit
  # (e.g. validate_path inside _sync_to/_sync_from) from the caller, so a
  # single bad step can't kill the whole sweep.
  if ( "$@" ); then return 0; fi
  FAILED_N=$((FAILED_N+1))
  log "  WARN: step failed: $*"
  return 1
}

# All encoded session dir names in LOCAL form: local dirs ∪ translated remote
# dirs (one ssh). Remote dirs outside the remote home prefix are skipped.
# Return code: 0 if remote discovery succeeded, nonzero if the remote_sh
# call itself failed (ssh/transport) -- callers MUST check this, since a
# swallowed discovery failure would silently degrade to a local-only sweep
# (empty union) while still reporting overall success.
union_session_dirs() {
  local d names rnames rn ln rc=0
  names=""
  for d in "$PROJECTS/$(local_home_encoded)"*; do
    if [ -d "$d" ]; then names="$names$(basename "$d")
"; fi
  done
  # Capture find's output BEFORE the basename loop: in `find | while`, the
  # pipeline's exit status is the while-loop's (always 0 at EOF) and find's
  # stderr is suppressed, so a genuinely failing find (missing dir,
  # permission, I/O error) would be silently swallowed and the union would
  # degrade to local-only while still reporting success. Bare `exit`
  # propagates find's nonzero status through remote_sh to the || below.
  rnames="$(remote_sh 'out="$(find "$1" -maxdepth 1 -mindepth 1 -type d -name "$2*" 2>/dev/null)" || exit
    printf "%s\n" "$out" | while read -r d; do [ -n "$d" ] || continue; basename "$d"; done' \
    "$RPROJECTS" "$(remote_home_encoded)")" || rc=1
  while IFS= read -r rn; do
    [ -n "$rn" ] || continue
    if ln="$(translate_dir "$rn" to-local 2>/dev/null)"; then names="$names$ln
"; fi
  done <<EOF
$rnames
EOF
  printf '%s' "$names" | sort -u | grep . || true
  return "$rc"
}

# Relative project paths (e.g. code/proj) under PROJECT_ROOTS that have a
# .claude dir on either side. Return code mirrors union_session_dirs above:
# nonzero means at least one remote discovery round failed and the union
# may be incomplete.
union_projects() {
  local root p rel rlist rc=0
  local out=""
  if [ ${#PROJECT_ROOTS[@]} -eq 0 ]; then return 0; fi
  for root in "${PROJECT_ROOTS[@]}"; do
    for p in "$HOME/$root"/*/; do
      if [ -d "${p}.claude" ]; then
        rel="${p#"$HOME"/}"; out="$out${rel%/}
"
      fi
    done
    # `if`, not `[ -d ] &&`: the for-loop's exit status is its last command's,
    # so a trailing project dir without .claude would read as a discovery
    # failure and spuriously fail the sweep.
    rlist="$(remote_sh 'root="$1"; for p in "$2/$root"/*/; do if [ -d "${p}.claude" ]; then printf "%s\n" "${p#"$2"/}"; fi; done 2>/dev/null' \
      "$root" "$RHOME")" || rc=1
    while IFS= read -r rel; do
      [ -n "$rel" ] || continue
      out="$out${rel%/}
"
    done <<EOF
$rlist
EOF
  done
  printf '%s' "$out" | sort -u | grep . || true
  return "$rc"
}

cmd_sync_all() {
  local direction="${1:-both}" name rname ldir rdir rel sub
  local sdirs sdirs_rc=0 prels prels_rc=0
  local unclean_rels="" unclean_n
  case "$direction" in both|to-remote|from-remote) ;; *) die "sync-all: direction must be both|to-remote|from-remote" ;; esac
  require_remote
  FAILED_N=0

  log "== sessions =="
  # Capture discovery output AND its exit code outside the `<<EOF ... EOF`
  # heredoc: `$(union_session_dirs)` there would run in its own command-
  # substitution subshell, so a nonzero return from it couldn't reach
  # FAILED_N in this scope at all -- discovery failure has to be checked
  # right here, before the loop consumes the (possibly incomplete) output.
  sdirs="$(union_session_dirs)" || sdirs_rc=$?
  if [ "$sdirs_rc" -ne 0 ]; then
    FAILED_N=$((FAILED_N+1))
    log "  WARN: remote discovery failed — union may be incomplete"
  fi
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    rname="$(translate_dir "$name" to-remote 2>/dev/null)" || continue
    ldir="$PROJECTS/$name"; rdir="$RPROJECTS/$rname"
    # validate_path dies on violation — run it in a subshell to skip instead.
    if ! (validate_path "$rdir") 2>/dev/null; then
      FAILED_N=$((FAILED_N+1)); log "  WARN: skipping unsafe path: $rdir"; continue
    fi
    mkdir -p "$ldir"
    if [ "$direction" != from-remote ]; then
      sync_try remote_sh 'mkdir -p "$1"' "$rdir" >/dev/null || true
      sync_try rsync -au "$ldir/" "$REMOTE:$rdir/" || true
    fi
    if [ "$direction" != to-remote ]; then
      sync_try rsync -au "$REMOTE:$rdir/" "$ldir/" || true
    fi
    log "  $name"
  done <<EOF
$sdirs
EOF

  log "== per-project .claude extras =="
  prels="$(union_projects)" || prels_rc=$?
  if [ "$prels_rc" -ne 0 ]; then
    FAILED_N=$((FAILED_N+1))
    log "  WARN: remote discovery failed — union may be incomplete"
  fi
  while IFS= read -r rel; do
    [ -n "$rel" ] || continue
    if [ ${#PROJECT_CLAUDE_EXTRAS[@]} -gt 0 ]; then
      for sub in "${PROJECT_CLAUDE_EXTRAS[@]}"; do
        if [ "$direction" != from-remote ]; then
          sync_try _sync_to "$HOME/$rel/.claude/$sub" "$RHOME/$rel/.claude/$sub" || true
        fi
        if [ "$direction" != to-remote ]; then
          sync_try _sync_from "$RHOME/$rel/.claude/$sub" "$HOME/$rel/.claude/$sub" || true
        fi
      done
    fi
    # git moves each project's CODE separately from what sync-all moves
    # here (sessions + .claude extras) -- flag any project whose repo has
    # uncommitted or unpushed work so its session(s) aren't silently synced
    # alongside code that isn't reachable on the other machine.
    repo_sync_state "$HOME/$rel"
    case "$REPO_STATE" in
      dirty|unpushed|no-upstream)
        unclean_rels="$unclean_rels  $rel: $REPO_STATE
"
        ;;
    esac
    log "  $rel"
  done <<EOF
$prels
EOF

  log "== home extras =="
  if [ ${#HOME_RELATIVE_EXTRAS[@]} -gt 0 ]; then
    for rel in "${HOME_RELATIVE_EXTRAS[@]}"; do
      if [ "$direction" != from-remote ]; then
        sync_try _sync_to "$HOME/$rel" "$RHOME/$rel" || true
      fi
      if [ "$direction" != to-remote ]; then
        sync_try _sync_from "$RHOME/$rel" "$HOME/$rel" || true
      fi
      log "  $rel"
    done
  fi

  if [ -n "$unclean_rels" ]; then
    unclean_n="$(printf '%s' "$unclean_rels" | grep -c .)"
    {
      printf 'WARNING: %s project(s) have uncommitted or unpushed work — their sessions may reference code not on the other machine:\n' "$unclean_n"
      printf '%s' "$unclean_rels"
    } >&2
    if [ "${REQUIRE_CLEAN:-0}" -eq 1 ]; then
      FAILED_N=$((FAILED_N+unclean_n))
    fi
  fi

  if [ "$FAILED_N" -gt 0 ]; then
    die "sync-all ($direction) finished with $FAILED_N failed step(s) — see WARN lines above"
  fi
  log "sync-all ($direction) complete"
}

# ---- tmux / handoff ----

# Find the tmux pane on the remote that owns a running `claude --resume <sid>`.
# Fail-closed single-line protocol: the CLI never silently proceeds when the
# remote state is uncertain. stdout is exactly one of:
#   OK <pane_id>        exactly one tmux pane runs this session (pane_id = %<n>)
#   NOPANE              tools present, no matching process is running
#   AMBIGUOUS <ids...>  more than one distinct pane matches, OR the topology is
#                       MIXED (some matches mapped to a pane, some did not) ->
#                       caller refuses: a pane-targeted stop could leave an
#                       unmapped matching writer running
#   NOTMUX              matching process(es) exist but none live in a tmux pane
#   NOTOOLS <tools...>  a required remote tool is missing -> state unverifiable
#   ERROR <stage> <rc>  a present tool FAILED at runtime  -> state unverifiable
# Every one of those exits 0 (they are answers). A NON-ZERO exit means the ssh
# transport itself failed, and find_remote_pane die()s -- "no pane" and "could
# not look" are never conflated. Pane identity is the STABLE tmux pane id
# (%<digits>), never the session:window.pane text (session names may contain
# spaces, so that text is unsafe to parse or use as a control target). The
# script travels as a single-quoted remote_sh payload; sid_re arrives as a
# quoted argv element ($1) and is only ever expanded on the remote side.
find_remote_pane() {
  local sid="$1" sid_re out rc
  # sid already validated to [A-Za-z0-9._-]; sid_re additionally escapes any
  # ERE-active `.` so it's safe inside the remote pgrep pattern (see sid_to_ere).
  sid_re="$(sid_to_ere "$sid")"
  # rc must be captured explicitly: under `set -e`, a failing command
  # substitution would exit the script before `rc=$?` runs, making the die
  # below dead code.
  set +e
  out=$(remote_sh 'set -u
sid_re=$1
# 1. Gateway tool: without pgrep we cannot even look for a match.
command -v pgrep >/dev/null 2>&1 || { echo "NOTOOLS pgrep"; exit 0; }
# 2. Matches. pgrep exit status: 0 = match(es), 1 = none, >1 = runtime error.
pids=$(pgrep -f "claude --resume[= ]${sid_re}( |\$)" 2>/dev/null); prc=$?
[ "$prc" -gt 1 ] && { echo "ERROR pgrep $prc"; exit 0; }
{ [ "$prc" -eq 1 ] || [ -z "$pids" ]; } && { echo NOPANE; exit 0; }
# 3. There ARE matches: ps/tmux/tr are now required to map pid -> pane id.
miss=""
for t in ps tmux tr; do command -v "$t" >/dev/null 2>&1 || miss="$miss $t"; done
[ -n "$miss" ] && { echo "NOTOOLS$miss"; exit 0; }
# 4. Snapshot the pane table once (pane_pid pane_id); fail closed on error.
panes=$(tmux list-panes -a -F "#{pane_pid} #{pane_id}" 2>/dev/null); trc=$?
[ "$trc" -ne 0 ] && { echo "ERROR tmux $trc"; exit 0; }
# 5. Walk each match up its ancestry to a pane_pid; collect DISTINCT pane ids
#    AND track whether EVERY match mapped to one. A match that walks to PID 1
#    or exhausts the hop limit is UNMAPPED, not ignorable. A pid that vanishes
#    mid-walk (ps rc 1, or an empty ppid: it exited between pgrep and here) is
#    also UNMAPPED; only ps rc > 1 is a real tool failure -> ERROR.
found=""; unmapped=0
for pid in $pids; do
  cur=$pid; hops=0; mapped=0
  while [ -n "$cur" ] && [ "$cur" -gt 1 ] 2>/dev/null; do
    hit=""; oldifs=$IFS; IFS="
"
    for row in $panes; do
      [ "${row%% *}" = "$cur" ] && { hit="${row#* }"; break; }
    done
    IFS=$oldifs
    if [ -n "$hit" ]; then
      mapped=1
      case " $found " in *" $hit "*) : ;; *) found="$found $hit" ;; esac
      break
    fi
    parent=$(ps -o ppid= -p "$cur" 2>/dev/null); prc2=$?
    [ "$prc2" -eq 1 ] && break
    [ "$prc2" -gt 1 ] && { echo "ERROR ps $prc2"; exit 0; }
    cur=$(printf "%s" "$parent" | tr -d "[:space:]")
    hops=$((hops+1)); [ "$hops" -gt 64 ] && break
  done
  [ "$mapped" -eq 0 ] && unmapped=1
done
found="${found# }"
[ -z "$found" ] && { echo NOTMUX; exit 0; }
# 6. MIXED topology fails closed: if ANY match did not map to a pane, a single
#    mapped pane must NOT be reported OK -- stopping that pane would leave the
#    unmapped matching writer running. Reuse AMBIGUOUS (callers already refuse
#    on it before any stop).
set -- $found
if [ "$unmapped" -eq 1 ]; then echo "AMBIGUOUS $found"
elif [ "$#" -eq 1 ]; then echo "OK $1"
else echo "AMBIGUOUS $found"; fi
exit 0' "$sid_re")
  rc=$?
  set -e
  if [ $rc -ne 0 ]; then
    die "ssh to $REMOTE failed while looking up the tmux pane (exit $rc)"
  fi
  printf '%s' "$out"
}

# Pane targets must be tmux pane ids: a literal % followed by digits. This is
# the stable identifier; the session:window.pane text can contain spaces and
# is not a safe control identity. Anything else is refused before it could
# reach send-keys.
validate_pane() {
  case "$1" in
    %[0-9]*) : ;;
    *) die "not a tmux pane id (expected %<digits>): '$1'" ;;
  esac
  case "${1#%}" in
    *[!0-9]*) die "not a tmux pane id (expected %<digits>): '$1'" ;;
  esac
}

# Resolve the remote pane for a stop, refusing BEFORE anything is stopped on
# any state that is not a clean single pane or a clean no-pane. Sets
# RESOLVED_PANE ('' when nothing is running). $2 is a verb for refusal text.
# A refusal here never strands the remote: nothing has been stopped yet.
RESOLVED_PANE=""
resolve_pane_or_refuse() {
  local sid="$1" verb="$2" info
  RESOLVED_PANE=""
  info="$(find_remote_pane "$sid")"
  case "$info" in
    "OK "*)
      RESOLVED_PANE="${info#OK }"
      validate_pane "$RESOLVED_PANE"
      log "found remote pane: $RESOLVED_PANE" ;;
    NOPANE)
      log "no remote pane is running this session" ;;
    "AMBIGUOUS "*)
      die "more than one tmux pane is running 'claude --resume $sid' (${info#AMBIGUOUS }); refusing to $verb so the wrong pane is never stopped (remote claude was NOT stopped). Close the extra session(s), or pass --no-stop and stop it yourself, then re-run" ;;
    NOTMUX)
      die "'claude --resume $sid' is running on the remote but not inside a tmux pane; claude-roam can only stop tmux-managed sessions (remote claude was NOT stopped). Stop it yourself, then re-run with --no-stop" ;;
    "NOTOOLS "*)
      die "cannot verify the remote session: required tool(s) missing on the remote (${info#NOTOOLS }); refusing to $verb (remote claude was NOT stopped). Install them (see 'claude-roam doctor'), or stop the remote claude yourself and re-run with --no-stop" ;;
    "ERROR "*)
      die "cannot verify the remote session (remote ${info#ERROR } failed); refusing to $verb so the wrong process is never stopped (remote claude was NOT stopped). Inspect the remote, or stop it yourself and re-run with --no-stop" ;;
    *)
      die "unexpected output from find_remote_pane: '$info' (remote claude was NOT stopped)" ;;
  esac
}

# Stop the claude running in $pane and wait up to 10s for the pid to clear.
# One remote_sh round trip does all the polling. Exit-status contract lets the
# caller tell "confirmed stopped" from "could not verify":
#   0    the process is confirmed gone
#   1    still running after 10s (timeout)
#   2    pgrep ERRORED on the remote  -> state UNKNOWN (never treated as gone)
#   255  ssh disconnected mid-stop    -> state UNKNOWN
stop_remote_claude() {
  local sid="$1" pane="$2" sid_re rc
  # See sid_to_ere: escapes ERE-active `.` before it reaches pgrep's pattern.
  sid_re="$(sid_to_ere "$sid")"
  validate_pane "$pane"
  # Capture rc explicitly (see find_remote_pane): under `set -e` a failing
  # remote_sh would exit before the case below could classify it.
  set +e
  remote_sh 'set -u
pane=$1; sid_re=$2
tmux send-keys -t "$pane" C-c 2>/dev/null
i=0
while [ "$i" -lt 10 ]; do
  i=$((i+1))
  sleep 1
  pgrep -f "claude --resume[= ]${sid_re}( |\$)" >/dev/null 2>&1; prc=$?
  [ "$prc" -eq 1 ] && exit 0
  [ "$prc" -gt 1 ] && exit 2
  [ "$i" -eq 5 ] && tmux send-keys -t "$pane" C-c 2>/dev/null
done
exit 1' "$pane" "$sid_re" >/dev/null 2>&1
  rc=$?
  set -e
  case "$rc" in
    0)   log "claude on remote stopped" ;;
    2)   die "could not verify the remote claude stopped (pgrep errored on the remote); remote state is UNKNOWN — inspect it before retrying (nothing was transferred)" ;;
    255) die "ssh to $REMOTE disconnected while stopping the remote claude; remote state is UNKNOWN — inspect it before retrying (nothing was transferred)" ;;
    *)   die "claude on remote did not exit after 10s; aborting to avoid data loss (the remote is still running)" ;;
  esac
}

# Restart claude in a pane on the HAPPY path only (recovery uses the safe
# re-checking path below) -- and VERIFY it. send-keys rc 0 proves only that
# the keys were DELIVERED, not that claude STARTED (claude not on the pane
# shell's PATH, a shell error, keys typed before the shell was ready). After
# the send, poll for a matching process in the SAME remote round trip (~8
# tries, ~4s budget, early-exit on the first match). Returns 0 ONLY when the
# restart is CONFIRMED; any other outcome (send failed, no process within the
# budget, ssh drop) is nonzero so the caller falls back to the armed recovery
# trap instead of reporting success. Bias: a slow start may misreport "not
# confirmed" (safe -- recovery RE-CHECKS before ever typing again); a false
# "restarted" must never happen.
restart_remote_claude() {
  local sid="$1" pane="$2" sid_re
  sid_re="$(sid_to_ere "$sid")"
  validate_pane "$pane"
  remote_sh 'set -u
pane=$1; sidlit=$2; sid_re=$3
tmux send-keys -t "$pane" "claude --resume $sidlit" Enter || exit 1
i=0
while [ "$i" -lt 8 ]; do
  i=$((i+1))
  sleep 0.5 2>/dev/null || sleep 1 2>/dev/null
  pgrep -f "claude --resume[= ]${sid_re}( |\$)" >/dev/null 2>&1 && exit 0
done
exit 1' "$pane" "$sid" "$sid_re" >/dev/null 2>&1
}

# ---- recovery: shared by handoff and handback ----
# When PANE is non-empty a recovery trap is armed. PHASE is 'stopping' (a
# failure here may pre-date a confirmed stop) or 'stopped-confirmed' (the stop
# returned success). All three globals are cleared on disarm.
ROAM_RECOVER_PANE=""; ROAM_RECOVER_SID=""; ROAM_RECOVER_PHASE=""

_roam_recover_disarm() {
  trap - EXIT
  ROAM_RECOVER_PANE=""; ROAM_RECOVER_SID=""; ROAM_RECOVER_PHASE=""
}

_recover_manual_hint() {  # $1=sid $2=pane
  log "  manual recovery: ssh $REMOTE \"tmux send-keys -t '$2' 'claude --resume $1' Enter\""
}

# ONE remote operation (H4): re-check for a live matching process AND, only if
# there is none, restart in the stored pane — the recheck happens immediately
# before send-keys, in a single ssh round trip, so the probe/restart window is
# as narrow as possible. RESTARTED is VERIFIED, not assumed from send-keys rc:
# after the send, the same round trip polls (~8 tries, ~4s budget) for the
# matching process; no match within the budget -> NOTSTARTED (keys delivered
# but the start was never confirmed). Prints one status word; a nonzero return
# is an ssh/transport failure. Residual limit: a fully external concurrent
# start between the recheck and the send-keys cannot be made atomic without a
# lock.
_recover_remote_op() {  # $1=sid $2=pane -> RESTARTED|RUNNING|NOPANEID|NOTSTARTED|SENDFAIL|NOTOOLS|ERROR <rc>
  local sid="$1" pane="$2" sid_re
  sid_re="$(sid_to_ere "$sid")"
  remote_sh 'set -u
pane=$1; sid_re=$2; sidlit=$3
command -v pgrep >/dev/null 2>&1 || { echo NOTOOLS; exit 0; }
pgrep -f "claude --resume[= ]${sid_re}( |\$)" >/dev/null 2>&1; prc=$?
[ "$prc" -eq 0 ] && { echo RUNNING; exit 0; }
[ "$prc" -gt 1 ] && { echo "ERROR $prc"; exit 0; }
for t in tmux grep; do command -v "$t" >/dev/null 2>&1 || { echo NOTOOLS; exit 0; }; done
tmux list-panes -a -F "#{pane_id}" 2>/dev/null | grep -qx "$pane" || { echo NOPANEID; exit 0; }
tmux send-keys -t "$pane" "claude --resume $sidlit" Enter 2>/dev/null || { echo SENDFAIL; exit 0; }
i=0
while [ "$i" -lt 8 ]; do
  i=$((i+1))
  sleep 0.5 2>/dev/null || sleep 1 2>/dev/null
  pgrep -f "claude --resume[= ]${sid_re}( |\$)" >/dev/null 2>&1 && { echo RESTARTED; exit 0; }
done
echo NOTSTARTED
exit 0' "$pane" "$sid_re" "$sid"
}

# Decision + logging around the op (the H1 recovery matrix). Restarts ONLY when
# the remote positively confirms no matching process is running. RUNNING /
# ERROR / NOTOOLS / a missing pane / ssh failure all mean a writer may still be
# alive, so those print a manual hint and never type into the pane.
_recover_restart() {  # $1=sid $2=pane
  local sid="$1" pane="$2" out rc
  validate_pane "$pane"
  set +e
  out="$(_recover_remote_op "$sid" "$pane")"
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    log "  could not reach $REMOTE to check/restart the session (ssh exit $rc); NOT restarting blindly."
    _recover_manual_hint "$sid" "$pane"
    return 0
  fi
  case "$out" in
    RESTARTED) log "  remote claude was not running; restarted it in $pane." ;;
    RUNNING)   log "  remote claude is still running in $pane; leaving it as-is (no restart needed)." ;;
    NOPANEID)  log "  the target pane $pane no longer exists; NOT restarting."
               _recover_manual_hint "$sid" "$pane" ;;
    NOTOOLS)   log "  a required remote tool is missing; cannot verify state, so NOT restarting."
               _recover_manual_hint "$sid" "$pane" ;;
    NOTSTARTED) log "  could not confirm claude restarted (keys were sent, but no matching process appeared) — check the pane."
               _recover_manual_hint "$sid" "$pane" ;;
    SENDFAIL)  log "  tmux send-keys failed; could not confirm claude restarted — check the pane."
               _recover_manual_hint "$sid" "$pane" ;;
    "ERROR "*) log "  could not verify remote state (${out}); NOT restarting to avoid a second writer."
               _recover_manual_hint "$sid" "$pane" ;;
    *)         log "  unexpected recovery result ('${out}'); NOT restarting."
               _recover_manual_hint "$sid" "$pane" ;;
  esac
  return 0
}

# EXIT-trap handler: single-fire, preserves the original exit code. M1: the
# FIRST statement MUST capture $?; only THEN may `trap - EXIT` run (it resets
# $? to 0). Do NOT log / assign / probe before the capture.
_remote_recover() {
  local rc=$?
  trap - EXIT
  local pane="$ROAM_RECOVER_PANE" sid="$ROAM_RECOVER_SID" phase="$ROAM_RECOVER_PHASE"
  ROAM_RECOVER_PANE=""; ROAM_RECOVER_SID=""; ROAM_RECOVER_PHASE=""
  if [ "$rc" -eq 0 ] || [ -z "$pane" ]; then
    exit "$rc"
  fi
  # Phase-sensitive: in the 'stopping' phase the stop was never confirmed, so
  # the remote may still be running -- do not claim it is stopped.
  if [ "$phase" = "stopping" ]; then
    log "operation FAILED (exit $rc); remote state unknown (a failure occurred while stopping) — checking whether the remote claude needs restarting..."
  else
    log "operation FAILED (exit $rc); the remote claude was stopped — checking whether it needs restarting..."
  fi
  _recover_restart "$sid" "$pane"
  exit "$rc"
}

cmd_handoff() {
  local sid="$1" pane="" local_file remote_file cmp lcwd lbranch=""
  require_remote

  # 1. Locate the remote pane (unless --no-stop). Refuses BEFORE any stop on an
  #    ambiguous or unverifiable state, so the wrong pane is never targeted and
  #    an active writer is never left running unnoticed. --no-stop assumes YOU
  #    already stopped the remote claude: discovery, stop, and restart are all
  #    skipped and handoff just pushes + pulls the repo + prints a start hint.
  if [ "$NO_STOP" -ne 1 ]; then
    resolve_pane_or_refuse "$sid" "hand off"
    pane="$RESOLVED_PANE"
  fi

  # 2. PREFLIGHT before stopping anything (a refusal here must not strand the remote).
  local_file="$(find_local_session "$sid")"
  remote_file="$RPROJECTS/$(translate_dir "$(basename "$(dirname "$local_file")")" to-remote)/${sid}.jsonl"
  # The push's rsync remote operand must pass validate_path -- check it HERE,
  # before the stop, so a space/metachar path refuses while the remote claude
  # is still running instead of dying inside cmd_push after it (the recovery
  # trap would restart it, but never stopping is strictly safer).
  _preflight_validate_path "$remote_file"
  cmp="$(compare_mtimes "$local_file" "$remote_file")"
  if [ "$cmp" = "remote-unknown" ]; then
    die "could not determine remote state (ssh/stat failed); refusing to proceed (remote claude was NOT stopped)"
  fi
  if [ "$cmp" = "remote-newer" ] && [ "$FORCE" -ne 1 ]; then
    die "remote is newer; pull/handback first or pass --force (remote claude was NOT stopped)"
  fi
  if [ "$cmp" = "diverged" ] && [ "$FORCE" -ne 1 ]; then
    die "local and remote have diverged; resolve first (remote claude was NOT stopped)"
  fi

  # Record the local branch for the remote pull sanity check.
  # Propagate a resolver failure (|| return $?) so it can't degrade to an
  # empty path in an errexit-disabled caller — consistent with the other
  # cwd assignments; this preflight runs before the remote is stopped.
  lcwd="$(session_cwd_local "$sid")" || return $?
  if git -C "$lcwd" rev-parse --abbrev-ref HEAD >/dev/null 2>&1; then
    lbranch="$(git -C "$lcwd" rev-parse --abbrev-ref HEAD)"
  fi

  # git moves the session's CODE separately from the JSONL handoff transfers
  # -- warn (or, with --require-clean, refuse) if the local project repo
  # isn't fully committed and pushed. This still runs BEFORE the remote
  # writer is stopped, so a --require-clean refusal never strands it.
  if ! warn_repo_unclean "$lcwd" "$lcwd"; then
    if [ "${REQUIRE_CLEAN:-0}" -eq 1 ]; then
      die "refusing to hand off: project repo at $lcwd is not clean (see WARNING above) — commit and push it, or drop --require-clean to proceed anyway (remote claude was NOT stopped)"
    fi
  fi

  # 3. Stop the remote writer. ARM recovery BEFORE the stop: a failure DURING
  #    the stop (Ctrl-C sent, then ssh drops or the poll times out, or
  #    stop_remote_claude die()s) must still reach the recovery trap. The phase
  #    flips to stopped-confirmed only once the stop returns success.
  if [ -n "$pane" ]; then
    ROAM_RECOVER_PANE="$pane"; ROAM_RECOVER_SID="$sid"; ROAM_RECOVER_PHASE="stopping"
    trap _remote_recover EXIT
    log "stopping claude in $pane..."
    stop_remote_claude "$sid" "$pane"
    ROAM_RECOVER_PHASE="stopped-confirmed"
  fi

  # 4. Transfer. The remote may have written shutdown records while exiting,
  # so the inner push runs forced — the preflight above already adjudicated.
  # Failures are propagated explicitly (not left to `set -e`) so the trap
  # fires the same way whether or not the caller runs under `set -e`.
  FORCE=1 cmd_push "$sid" || return $?

  # 5. Repo pull (branch-checked) + extras.
  cmd_repo_pull "$sid" "$lbranch" || return $?
  if [ "$NO_EXTRAS" -ne 1 ]; then
    cmd_sync_extras "$sid" to-remote || return $?
  fi

  # 6. Restart FIRST, disarm ONLY on a CONFIRMED restart (the matching process
  # was actually observed after the send — see restart_remote_claude). On any
  # unconfirmed outcome (send failed, keys delivered but no process appeared,
  # ssh dropped) the trap stays armed: exiting nonzero fires _remote_recover,
  # which RE-CHECKS before typing again — so a half-successful send never
  # double-starts, and an unstarted claude is never reported as "handoff
  # complete". We also print the manual hint directly for visibility.
  if [ -n "$pane" ]; then
    log "resuming session in $pane..."
    if restart_remote_claude "$sid" "$pane"; then
      _roam_recover_disarm
      log "handoff complete. the session is running again in pane $pane on $REMOTE."
      log "  attach with: ssh $REMOTE -t tmux attach -t '$pane'"
    else
      log "could not confirm claude restarted — check the pane."
      _recover_manual_hint "$sid" "$pane"
      exit 1
    fi
  else
    log ""
    log "to start the session, attach a tmux session on the remote and run:"
    log "  claude --resume $sid"
  fi
}

cmd_handback() {
  local sid="$1" pane="" remote_file local_file cmp
  local hb_lcwd="" hb_rcwd="" lparent hb_cands hb_rc=0 extras_rc=0
  require_remote

  # 1. Locate the remote pane (mirrors handoff step 1); refuses before any stop
  #    on an ambiguous / unverifiable state. --no-stop skips discovery entirely
  #    and assumes YOU already stopped the remote claude.
  if [ "$NO_STOP" -ne 1 ]; then
    resolve_pane_or_refuse "$sid" "hand back"
    pane="$RESOLVED_PANE"
  fi

  # 2. PREFLIGHT before stopping anything (a refusal here must not strand the remote).
  remote_file="$(find_remote_session "$sid")"
  local_file="$PROJECTS/$(translate_dir "$(basename "$(dirname "$remote_file")")" to-local)/${sid}.jsonl"
  # The pull's rsync remote operand must pass validate_path -- check it HERE,
  # before the stop, so a space/metachar path refuses while the remote claude
  # is still running instead of dying inside cmd_pull after it (which would
  # strand a stopped remote AND skip the resume hint below).
  _preflight_validate_path "$remote_file"
  cmp="$(compare_mtimes "$local_file" "$remote_file")"
  if [ "$cmp" = "remote-unknown" ]; then
    die "could not determine remote state (ssh/stat failed); refusing to proceed (remote claude was NOT stopped)"
  fi
  if [ "$cmp" = "local-newer" ] && [ "$FORCE" -ne 1 ]; then
    die "local is newer; push first or pass --force (remote claude was NOT stopped)"
  fi
  if [ "$cmp" = "diverged" ] && [ "$FORCE" -ne 1 ]; then
    die "local and remote have diverged; resolve first (remote claude was NOT stopped)"
  fi

  # 2b. Resolve the project cwd from the REMOTE transcript that is ABOUT to be
  # pulled -- not any stale local copy, which the pull will replace. A
  # remote-origin session carries a remote-home cwd, and extras cannot proceed
  # until we can map it to a local project dir. Doing it here, before the stop,
  # means an unresolvable/ambiguous cwd refuses while the remote is still
  # running rather than stranding it after the stop. The validated result is
  # carried into the post-pull extras step (no re-parsing of mutable data).
  if [ "$NO_EXTRAS" -ne 1 ]; then
    lparent="$(translate_dir "$(basename "$(dirname "$remote_file")")" to-local)"
    # Extraction runs separately from the resolve pipeline so the snippet's
    # "no jq/python3 on the remote" sentinel (exit 3) can surface as its own
    # actionable refusal instead of a generic "could not resolve".
    hb_cands="$(remote_sh "$(cwd_extract_script)" "$remote_file")" || hb_rc=$?
    if [ "$hb_rc" -eq 3 ]; then
      die "cwd resolution requires jq or python3 on the remote; install one there (remote claude was NOT stopped). Re-run with --no-extras to pull the transcript only"
    fi
    hb_rc=0
    hb_lcwd="$(printf '%s' "$hb_cands" | _resolve_cwd_stream "$lparent")" || hb_rc=$?
    if [ "$hb_rc" -ne 0 ] || [ -z "$hb_lcwd" ]; then
      die "could not resolve the session's project dir from the remote transcript (project '$lparent'); refusing to hand back (remote claude was NOT stopped). Re-run with --no-extras to pull the transcript only"
    fi
    # Extras sync requires an under-$HOME project. An outside-$HOME candidate
    # can slip through resolution via the '/'<->'-' encoding collision (e.g.
    # /Users-alice/code/app direct-encodes to an under-home parent) but has
    # no remote counterpart -- session_cwd_remote refuses such a cwd -- so
    # refuse it HERE, before the stop, instead of failing after stop+pull.
    # This case is exhaustive: hb_rcwd is always non-empty past this point.
    case "$hb_lcwd" in
      "$HOME"|"$HOME"/*) hb_rcwd="$RHOME${hb_lcwd#"$HOME"}" ;;
      *) die "resolved project dir '$hb_lcwd' is outside local \$HOME; extras cannot be mapped to the remote (remote claude was NOT stopped). Re-run with --no-extras to pull the transcript only" ;;
    esac
    # The extras rsync remote operands derive from this path -- same
    # before-the-stop validation as the transcript path above.
    _preflight_validate_path "$hb_rcwd"
  fi

  # 3. Stop the remote writer — pulling while it writes tears the copy. ARM
  #    recovery BEFORE the stop (mirrors handoff): a failure during the stop or
  #    the pull must be able to restart the remote, because control has NOT yet
  #    moved local. The phase flips to stopped-confirmed once the stop returns.
  if [ -n "$pane" ]; then
    ROAM_RECOVER_PANE="$pane"; ROAM_RECOVER_SID="$sid"; ROAM_RECOVER_PHASE="stopping"
    trap _remote_recover EXIT
    log "stopping remote claude in $pane before pulling..."
    stop_remote_claude "$sid" "$pane"
    ROAM_RECOVER_PHASE="stopped-confirmed"
  fi

  # 4. Pull. The remote may have written shutdown records while exiting
  # (making it look newer), so the inner pull runs forced — the preflight
  # above already adjudicated. Propagate a pull failure explicitly (|| return)
  # so the armed trap fires: a nonzero pull leaves the local copy UNCONFIRMED
  # (rsync writes a temp file and renames only on success), so the remote is
  # still authoritative and MUST be restarted.
  FORCE=1 cmd_pull "$sid" || return $?
  # The pull SUCCEEDED: the authoritative copy is now local. Disarm BEFORE
  # extras — from here a failure must NOT restart the remote (that would
  # recreate a dual writer for a session whose control has moved local).
  if [ -n "$pane" ]; then
    _roam_recover_disarm
  fi
  if [ "$NO_EXTRAS" -ne 1 ]; then
    # Pass the pre-validated cwds forward (both guaranteed non-empty: the
    # preflight above refused outside-$HOME cwds, so extras never re-parse
    # mutable data). Run in a SUBSHELL so even a die/exit inside extras is
    # captured as extras_rc rather than exiting the shell -- the transcript
    # is already safely local, and the resume hint below must always print
    # after a successful pull.
    ( cmd_sync_extras "$sid" from-remote "$hb_lcwd" "$hb_rcwd" ) || extras_rc=$?
  fi
  log ""
  log "to resume locally, cd to the matching project dir and run:"
  log "  claude --resume $sid"
  if [ "$extras_rc" -ne 0 ]; then
    log ""
    log "WARNING: the transcript pulled cleanly but syncing its extras failed (exit $extras_rc)."
    log "  the session is usable locally; re-run: claude-roam sync-extras $sid from-remote"
    return "$extras_rc"
  fi
}

# ---- doctor ----

DOCTOR_FAILS=0
_dr_ok()   { log "ok   $*"; }
_dr_warn() { log "warn $*"; }
_dr_fail() { DOCTOR_FAILS=$((DOCTOR_FAILS+1)); log "FAIL $*"; }

cmd_doctor() {
  DOCTOR_FAILS=0
  log "-- local --"
  _dr_ok "bash ${BASH_VERSION}"
  log "     this claude-roam: $0"
  if [ -L "$0" ]; then log "     resolves to: $(readlink "$0")"; fi
  local t
  for t in ssh rsync git find stat sort date; do
    if command -v "$t" >/dev/null 2>&1; then _dr_ok "$t present"; else _dr_fail "$t missing"; fi
  done
  if command -v tmux >/dev/null 2>&1; then _dr_ok "tmux present"; else _dr_warn "tmux missing (handoff pane restart unavailable)"; fi
  if command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1; then
    _dr_ok "jq or python3 present (JSONL cwd resolution)"
  else _dr_warn "no jq/python3 — cwd resolution requires one; project/handoff/handback/sync-extras will fail until jq or python3 is installed"; fi
  # Capture then log — piping into `while read` would run the loop in a
  # subshell, discarding anything it sets (see the remote block below).
  local rsync_ver
  rsync_ver="$(rsync --version 2>/dev/null | head -1)"
  if [ -n "$rsync_ver" ]; then log "     rsync: $rsync_ver"; fi
  if [ -d "$PROJECTS" ]; then _dr_ok "projects dir $PROJECTS"; else _dr_warn "projects dir missing: $PROJECTS (run Claude Code once)"; fi
  # shellcheck disable=SC2088  # literal display text, not an unexpanded path
  case ":$PATH:" in *":$HOME/.local/bin:"*) _dr_ok "~/.local/bin on PATH" ;; *) _dr_warn "~/.local/bin not on PATH" ;; esac
  local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/claude-roam/config"
  if [ -f "$cfg" ]; then _dr_ok "config $cfg"; else _dr_warn "no config file at $cfg"; fi

  log "-- remote --"
  local resolved="${REMOTE_FLAG:-${CLAUDE_ROAM_REMOTE:-}}"
  if [ -z "$resolved" ]; then
    log "     no remote configured — set one to enable remote checks"
  else
    require_remote
    _dr_ok "ssh $REMOTE (home: $RHOME)"
    # Capture remote output into a variable FIRST, then iterate it in the
    # current shell via a heredoc. Piping remote_sh straight into
    # `while read` would fork the loop into a subshell, so
    # DOCTOR_FAILS=$((DOCTOR_FAILS+1)) inside it could never mutate the
    # real counter here — same idiom as cmd_sync_all's `done <<EOF ...`.
    local remote_out line
    remote_out="$(remote_sh 'for t in rsync git find stat sort date; do
  if command -v "$t" >/dev/null 2>&1; then echo "ok   remote $t present"; else echo "FAIL remote $t missing"; fi
done
rsync_ver=$(rsync --version 2>/dev/null | head -1)
if [ -n "$rsync_ver" ]; then echo "     remote rsync: $rsync_ver"; fi
if command -v tmux >/dev/null 2>&1; then echo "ok   remote tmux present"; else echo "warn remote tmux missing"; fi
for t in pgrep ps awk; do
  if command -v "$t" >/dev/null 2>&1; then echo "ok   remote $t present"; else echo "warn remote $t missing — handoff cannot locate/stop the remote session without it"; fi
done
# handoff restarts claude by typing "claude --resume" into the tmux pane,
# where the LOGIN/INTERACTIVE shell resolves it — so probe THAT PATH, not
# this bare non-interactive ssh PATH (which excludes mise / ~/.local/bin
# and would false-alarm on a perfectly working install). </dev/null keeps
# the interactive shell from hanging while it waits on stdin.
if bash -lic "command -v claude >/dev/null 2>&1" </dev/null >/dev/null 2>&1; then
  echo "ok   remote claude present (on the login-shell PATH)"
else
  echo "warn remote claude not found on the login-shell PATH — handoff restarts the session by typing claude --resume into the tmux pane, so claude must be on your interactive shell PATH (e.g. mise or ~/.local/bin)"
fi
if command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1; then
  echo "ok   remote jq or python3 present (JSONL cwd resolution)"
else
  echo "warn remote jq/python3 missing — handback cwd resolution will fail; install one on the remote"
fi
if [ -d "$1" ]; then echo "ok   remote projects dir $1"; else echo "warn remote projects dir missing: $1 (run Claude Code once there)"; fi' "$RPROJECTS")"
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      log "$line"
      case "$line" in FAIL*) DOCTOR_FAILS=$((DOCTOR_FAILS+1)) ;; esac
    done <<EOF
$remote_out
EOF
  fi

  if [ "$DOCTOR_FAILS" -gt 0 ]; then die "doctor: $DOCTOR_FAILS hard failure(s)"; fi
  log "doctor: all checks passed"
}

# ---- arg parsing / main ----

parse_args() {
  REMOTE_FLAG=""; FORCE=0; NO_EXTRAS=0; NO_STOP=0; REQUIRE_CLEAN=0
  PARSED=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --remote)    [ $# -ge 2 ] || die "--remote needs a host argument"
                   REMOTE_FLAG="$2"; shift 2 ;;
      --force)     FORCE=1; shift ;;
      --no-extras) NO_EXTRAS=1; shift ;;
      --no-stop)   NO_STOP=1; shift ;;
      --require-clean) REQUIRE_CLEAN=1; shift ;;
      -h|--help)   usage; exit 0 ;;
      --)          shift; PARSED+=("$@"); break ;;
      *)           PARSED+=("$1"); shift ;;
    esac
  done
}

dispatch() {
  local sub="${1:-}"
  if [ $# -gt 0 ]; then shift; fi
  case "$sub" in
    push) [ $# -ge 1 ] || die "push needs <session-id>"; validate_sid "$1"; cmd_push "$1" ;;
    pull) [ $# -ge 1 ] || die "pull needs <session-id>"; validate_sid "$1"; cmd_pull "$1" ;;
    project)     [ $# -ge 1 ] || die "project needs <session-id>";     validate_sid "$1"; cmd_project "$1" "${2:-local}" ;;
    repo-status)
      [ $# -ge 1 ] || die "repo-status needs <session-id>"
      validate_sid "$1"
      case "${2:-local}" in
        local)  cmd_repo_status "$1" ;;
        remote) cmd_repo_status_remote "$1" ;;
        *) die "repo-status: unknown mode '${2}' (use 'local' or 'remote')" ;;
      esac
      ;;
    repo-pull)   [ $# -ge 1 ] || die "repo-pull needs <session-id>";   validate_sid "$1"; cmd_repo_pull "$1" ;;
    sync-extras) [ $# -ge 1 ] || die "sync-extras needs <session-id>"; validate_sid "$1"; cmd_sync_extras "$1" "${2:-to-remote}" ;;
    sync-all) cmd_sync_all "${1:-both}" ;;
    handoff)  [ $# -ge 1 ] || die "handoff needs <session-id>";  validate_sid "$1"; cmd_handoff "$1" ;;
    handback) [ $# -ge 1 ] || die "handback needs <session-id>"; validate_sid "$1"; cmd_handback "$1" ;;
    list)        validate_int "${1:-30}"; cmd_list   "${1:-30}" ;;
    recent)      validate_int "${1:-10}"; cmd_recent "${1:-10}" ;;
    doctor) cmd_doctor ;;
    ""|help) usage ;;
    *)       die "unknown subcommand: $sub" ;;
  esac
}

main() {
  set -euo pipefail
  load_config
  parse_args "$@"
  # Bash 3.2 expands "${PARSED[@]:-}" to one empty positional when empty; avoid.
  if [ ${#PARSED[@]} -gt 0 ]; then dispatch "${PARSED[@]}"; else dispatch; fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
